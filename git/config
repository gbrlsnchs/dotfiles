# vim: ft=gitconfig

[user]
	name = Gabriel Sanches
	email = gabriel@gsr.dev
[core]
	editor = /bin/nvim
	pager = nvim -c 'Man! | setf git'
[init]
	defaultbranch = trunk
[pull]
	rebase = true
[url "git@github.com:"]
	insteadOf = https://github.com/
[color]
	pager = no
[diff]
	tool = nvr
[difftool "nvr"]
	cmd = nvr -s -d $LOCAL $REMOTE
[merge]
	tool = nvr
[mergetool "nvr"]
	cmd = nvr -s -d $LOCAL $BASE $REMOTE $MERGED -c 'wincmd J | wincmd ='
